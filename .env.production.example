# Copy into Vercel → Project → Settings → Environment Variables (Production), then redeploy.
# NEXT_PUBLIC_* is baked in at `next build`.
#
# Root Directory in Vercel must be `cineprompt-ai`. Monorepo root `.env.production` is not used by Next.
#
# Razorpay: do not add Razorpay keys to the frontend. Set RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET,
# RAZORPAY_WEBHOOK_SECRET on the API only (see cinePrompt-api/.env.production.example).

NEXT_PUBLIC_API_BASE_URL=https://cineprompt-api-production.up.railway.app/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=343746941144-ucvr6cnrsi85fopbqjmsd7voc1ucgdig.apps.googleusercontent.com

# Optional: only if the public API origin differs from the URL above without /api
# NEXT_PUBLIC_DATACAPTAIN_URL=https://cineprompt-api-production.up.railway.app
