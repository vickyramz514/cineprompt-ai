# Frontend (Next.js) — copy to .env.local
# Vercel: set the same NEXT_PUBLIC_* in Project → Environment Variables.

# API base (must end with /api)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Optional: public API origin without /api (defaults from NEXT_PUBLIC_API_BASE_URL)
# NEXT_PUBLIC_DATACAPTAIN_URL=http://localhost:4000

# Razorpay: key secret stays on the API only. The API returns razorpayKeyId (public) for Standard Checkout + redirect back to the app after payment.
