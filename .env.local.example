# CinePrompt AI / Data Captain - Frontend Environment
# Copy to .env.local (local) or set these in your host’s dashboard (production).
# Vercel: Root Directory = `cineprompt-ai` — a `.env.production` at the monorepo root is NOT used by Next.

# API — path must end with /api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Google Sign-In (Web client) — required for the Google button to work.
# Create: https://console.cloud.google.com/apis/credentials → Create credentials → OAuth client ID → Web application
#
# Local: add Authorized JavaScript origins → http://localhost:3000
# Production: add → https://YOUR_DOMAIN (e.g. https://app.example.com)
# Backend must use the same client (GOOGLE_CLIENT_ID) to verify tokens.
#
# Vercel / Railway / etc.: add under Environment Variables (Production), then redeploy.
# NEXT_PUBLIC_* is embedded at build time — set it before `next build`.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
